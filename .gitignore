.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Archivos del Sistema Operativo
.DS_Store
Thumbs.db
Desktop.ini

# Configuración de Editores (Opcional, pero recomendado)
.vscode/
.idea/
*.swp
*.swo

